@{
    ViewData["Title"] = "Elovo Google Login";
    var googleClientId = ViewBag.GoogleClientId as string;
    var googleLoginUri = ViewBag.GoogleLoginUri as string;
    var hasGoogleClientId = !string.IsNullOrWhiteSpace(googleClientId);
}

<main class="app-shell">
    <section class="login-view is-active" aria-label="Google login">
        <div class="brand-panel">
            <img class="brand-logo" src="~/Assets/Images/Logo/Elovo-Logo.png" alt="Elovo logo">
            <p class="eyebrow">Elovo Chat</p>
            <h1>Sign in with your Google account.</h1>
            <p class="support-copy">Use the verified email already attached to your Elovo profile.</p>
        </div>

        <div class="login-card">
            <div>
                <span class="form-kicker">Google auth</span>
                <h2>Continue</h2>
            </div>

            @if (hasGoogleClientId)
            {
                <div id="g_id_onload"
                     data-client_id="@googleClientId"
                     data-login_uri="@googleLoginUri"
                     data-auto_prompt="false">
                </div>
                <div class="google-signin-shell">
                    <div class="g_id_signin"
                         data-type="standard"
                         data-size="large"
                         data-theme="outline"
                         data-text="signin_with"
                         data-shape="rectangular"
                         data-logo_alignment="left">
                    </div>
                </div>
            }
            else
            {
                <p class="error-message" style="color: red; display: block; margin-top: 10px; font-size: 0.875rem;">Google sign-in is not configured.</p>
            }

            <a asp-action="Login" asp-controller="Auth" class="secondary-button">Back to login</a>
        </div>
    </section>
</main>

@section Scripts {
    @if (hasGoogleClientId)
    {
        <script src="https://accounts.google.com/gsi/client" async defer></script>
    }
}
