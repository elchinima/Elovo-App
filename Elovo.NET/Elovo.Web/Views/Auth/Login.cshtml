@model Elovo.Application.DTOs.LoginDto
@{
    ViewData["Title"] = "Elovo Login";
    var hasError = !string.IsNullOrWhiteSpace(ViewBag.Error as string);
}

<main class="app-shell">
    <section class="login-view is-active" id="loginView" aria-label="Login">
        <div class="brand-panel">
            <img class="brand-logo" src="~/Assets/Images/Logo/Elovo-Logo.png" alt="Elovo logo">
            <p class="eyebrow">Elovo Chat</p>
            <h1>Sign in to your secure workspace.</h1>
            <p class="support-copy">A full-featured messenger built around fast conversations, shared files, and calm focus.</p>
        </div>

        <form class="login-card" id="loginForm" asp-action="Login" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()
            <div>
                <span class="form-kicker">Welcome back</span>
                <h2>Log in</h2>
            </div>
            <label>
                Username
                <input type="text" id="loginUsername" name="Username" value="@Model?.Username" required>
            </label>
            <label>
                Password
                <input type="password" id="loginPassword" name="Password" required>
            </label>
            <div class="auth-action-row">
                <button class="primary-icon-button" type="submit" aria-label="Enter Messenger" title="Enter Messenger">
                    <img class="button-icon" src="~/Assets/Images/Icons/login.svg" alt="">
                    <span>Log in</span>
                </button>
                <a class="google-auth-button" href="/google-login" aria-label="Continue with Google" title="Continue with Google">
                    <img class="google-auth-icon" src="~/Assets/Images/Icons/google.svg" alt="">
                </a>
            </div>
            <a asp-action="Register" asp-controller="Auth" class="secondary-button">Create a new account</a>
            <p class="error-message" id="loginError" style="color: red; display: @(hasError ? "block" : "none"); margin-top: 10px; font-size: 0.875rem;">@(ViewBag.Error ?? "Invalid username or password.")</p>
        </form>
    </section>
</main>

@section Scripts {
    <script src="~/Assets/Script/login.js" asp-append-version="true"></script>
}
