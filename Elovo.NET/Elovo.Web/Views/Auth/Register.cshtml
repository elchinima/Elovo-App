@model Elovo.Application.DTOs.RegisterDto
@{
    ViewData["Title"] = "Elovo Register";
    var hasError = !string.IsNullOrWhiteSpace(ViewBag.Error as string);
}

<main class="app-shell">
    <section class="login-view is-active" aria-label="Register">
        <div class="brand-panel">
            <img class="brand-logo" src="~/Assets/Images/Logo/Elovo-Logo.png" alt="Elovo logo">
            <p class="eyebrow">Elovo Chat</p>
            <h1>Get started with your secure workspace.</h1>
            <p class="support-copy">A polished messenger simulation built around fast conversations, shared files, and calm focus.</p>
        </div>

        <form class="login-card" id="registerForm" asp-action="Register" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()
            <div>
                <span class="form-kicker">Welcome</span>
                <h2>Create Account</h2>
            </div>
            <label>
                Username
                <input type="text" id="regUsername" name="Username" value="@Model?.Username" minlength="3" maxlength="32" required>
            </label>
            <label>
                Password
                <input type="password" id="regPassword" name="Password" minlength="8" maxlength="128" required>
            </label>
            <button class="primary-icon-button" type="submit" aria-label="Create Account" title="Create Account">
                <img class="button-icon" src="~/Assets/Images/Icons/signup.svg" alt="">
                <span>Sign up</span>
            </button>
            <a asp-action="Login" asp-controller="Auth" class="secondary-button">Already have an account? Log in</a>
            <p class="error-message" id="regError" style="color: red; display: @(hasError ? "block" : "none"); margin-top: 10px; font-size: 0.875rem;">@(ViewBag.Error ?? "Username already exists.")</p>
        </form>
    </section>
</main>
