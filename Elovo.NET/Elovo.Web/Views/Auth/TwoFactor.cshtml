@model Elovo.Application.DTOs.VerifyTwoFactorDto
@{
    ViewData["Title"] = "Elovo Verification";
    var hasError = !string.IsNullOrWhiteSpace(ViewBag.Error as string);
    var email = ViewBag.Email as string;
    var emailCooldownEndsAt = ViewBag.EmailCooldownEndsAt as string;
}

<main class="app-shell">
    <section class="login-view is-active" aria-label="Two-factor verification">
        <div class="brand-panel">
            <img class="brand-logo" src="~/Assets/Images/Logo/Elovo-Logo.png" alt="Elovo logo">
            <p class="eyebrow">Two-factor authentication</p>
            <h1>Check your email to continue.</h1>
            <p class="support-copy">Enter the 7 digit sign-in code. It is active for 1 hour.</p>
        </div>

        <form class="login-card" id="twoFactorForm" asp-action="TwoFactor" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()
            <div>
                <span class="form-kicker">Security check</span>
                <h2>Verification</h2>
            </div>
            @if (!string.IsNullOrWhiteSpace(email))
            {
                <p class="fine-print"><span>Code sent to</span> @email</p>
            }
            <p class="fine-print two-factor-email-timer" id="twoFactorEmailTimer" data-cooldown-ends-at="@emailCooldownEndsAt"></p>
            <label>
                Code
                <input type="text" id="twoFactorCode" name="Code" value="@Model?.Code" inputmode="numeric" pattern="[0-9]{7}" maxlength="7" autocomplete="one-time-code" required>
            </label>
            <button class="primary-icon-button" type="submit" aria-label="Verify code" title="Verify code">
                <img class="button-icon" src="~/Assets/Images/Icons/two-factor.svg" alt="">
                <span>Verify</span>
            </button>
            <a asp-action="Login" asp-controller="Auth" class="secondary-button">Back to login</a>
            <p class="error-message" id="twoFactorError" style="color: red; display: @(hasError ? "block" : "none"); margin-top: 10px; font-size: 0.875rem;">@(ViewBag.Error ?? "Verification failed.")</p>
        </form>
    </section>
</main>

@section Scripts {
    <script src="~/Assets/Script/two-factor.js" asp-append-version="true"></script>
}
