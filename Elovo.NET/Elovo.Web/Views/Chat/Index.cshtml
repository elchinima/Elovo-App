@{
    ViewData["Title"] = "Elovo Chat";
}

<main class="app-shell">
    <section class="messenger-view is-active" id="messengerView" aria-label="Messenger">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="brand-mark" id="currentUserAvatar">
                    @if (!string.IsNullOrWhiteSpace(ViewBag.CurrentUserProfileImageUrl as string))
                    {
                        <img class="profile-image" src="@ViewBag.CurrentUserProfileImageUrl" alt="">
                    }
                    else
                    {
                        <span>@(ViewBag.CurrentUserInitial ?? "E")</span>
                    }
                </div>
                <div>
                    <p>Elovo</p>
                    <strong>Messages</strong>
                </div>
                <div class="sidebar-actions">
                    <button class="icon-button hidden-chats-button" id="restoreHiddenButton" type="button" aria-label="Show hidden chats" title="Show hidden chats" hidden>
                        <img class="button-icon" src="~/Assets/Images/Icons/hidden-chats.svg" alt="">
                    </button>
                    <button class="icon-button sidebar-settings-button" id="settingsButton" type="button" aria-label="Settings" title="Settings">
                        <img class="button-icon" src="~/Assets/Images/Icons/settings.svg" alt="">
                    </button>
                </div>
            </div>

            <div class="search-box">
                <label for="searchInput">Search</label>
                <input type="search" id="searchInput" placeholder="Search chats">
                <button class="icon-button search-button" id="chatSearchButton" type="button" aria-label="Search chats" title="Search">
                    <img class="button-icon" src="~/Assets/Images/Icons/search.svg" alt="">
                </button>
            </div>

            <div class="chat-list" id="chatList" aria-label="Conversation list"></div>

            <nav class="friend-action-dock" aria-label="Friend actions">
                <button class="icon-button dock-button" id="allFriendsButton" type="button" aria-label="All friends" title="All friends">
                    <img class="button-icon" src="~/Assets/Images/Icons/all-friends.svg" alt="">
                </button>
                <button class="icon-button dock-button dock-button-primary" id="addFriendButton" type="button" aria-label="Add friend" title="Add friend">
                    <img class="button-icon" src="~/Assets/Images/Icons/add-friend.svg" alt="">
                </button>
                <button class="icon-button dock-button" id="friendRequestsButton" type="button" aria-label="Friend requests" title="Friend requests">
                    <img class="button-icon" src="~/Assets/Images/Icons/friend-requests.svg" alt="">
                </button>
            </nav>
        </aside>

        <section class="chat-panel">
            <header class="chat-header">
                <button class="icon-button mobile-back" id="backButton" type="button" aria-label="Back to conversations" title="Back">
                    <img class="button-icon" src="~/Assets/Images/Icons/back.svg" alt="">
                </button>
                <div class="avatar" id="activeAvatar">E</div>
                <div class="active-chat-summary" id="activeChatSummary">
                    <h2 id="activeName">Elovo</h2>
                    <p id="activeStatus">Choose a conversation</p>
                </div>
                <button class="ghost-button" id="callButton" type="button" aria-label="Start audio call" title="Audio call" aria-pressed="false" disabled>
                    <img class="button-icon" src="~/Assets/Images/Icons/call.svg" alt="">
                </button>
            </header>

            <div class="message-stream" id="messageStream" aria-live="polite"></div>

            <form class="composer" id="messageForm">
                @Html.AntiForgeryToken()
                <button type="button" class="icon-button" id="attachImageButton" aria-label="Attach image" title="Attach image">
                    <img class="button-icon" src="~/Assets/Images/Icons/attach.svg" alt="">
                </button>
                <input class="visually-hidden-file" type="file" id="imageInput" accept="image/png,image/jpeg,image/jpg,image/gif">
                <input type="text" id="messageInput" placeholder="Write a message" autocomplete="off">
                <button class="send-button" type="submit" aria-label="Send message" title="Send message">
                    <img class="button-icon" id="messageSubmitIcon" src="~/Assets/Images/Icons/voice-message.svg" alt="">
                </button>
            </form>
        </section>
    </section>

    <section class="settings-frame-shell" id="settingsFrameShell" aria-label="Settings" aria-hidden="true" hidden>
        <iframe id="settingsFrame" title="Settings"></iframe>
    </section>

    <aside class="active-call-banner" id="activeCallBanner" aria-label="Active audio call" hidden>
        <div class="active-call-banner-copy">
            <strong id="activeCallBannerName">Audio call</strong>
            <span id="activeCallBannerDuration">00:00</span>
        </div>
        <div class="active-call-banner-actions" aria-label="Active call controls">
            <button class="active-call-banner-button" id="activeCallBannerMuteButton" type="button" aria-label="Mute microphone" title="Mute microphone" aria-pressed="false">
                <img class="button-icon" src="~/Assets/Images/Icons/microphone.svg" alt="">
            </button>
            <button class="active-call-banner-button" id="activeCallBannerEndButton" type="button" aria-label="End call" title="End call">
                <img class="button-icon" src="~/Assets/Images/Icons/call-end.svg" alt="">
            </button>
        </div>
    </aside>

    <div class="modal-backdrop" id="addFriendModal" aria-hidden="true">
        <section class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="addFriendTitle">
            <header class="modal-header">
                <h2 id="addFriendTitle">Add friend</h2>
                <button class="icon-button" type="button" data-close-modal aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="search-box modal-search">
                <label for="userSearchInput">Search users</label>
                <input type="search" id="userSearchInput" placeholder="Search by username">
                <button class="icon-button search-button" id="userSearchButton" type="button" aria-label="Search users" title="Search">
                    <img class="button-icon" src="~/Assets/Images/Icons/search.svg" alt="">
                </button>
            </div>
            <div class="modal-list" id="userSearchResults"></div>
        </section>
    </div>

    <div class="modal-backdrop restore-hidden-backdrop" id="restoreHiddenModal" aria-hidden="true">
        <section class="modal-panel confirm-modal-panel restore-hidden-panel" role="dialog" aria-modal="true" aria-labelledby="restoreHiddenTitle">
            <header class="modal-header">
                <h2 id="restoreHiddenTitle">Show hidden conversations?</h2>
                <button class="icon-button" type="button" data-close-modal aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="confirm-modal-body">
                <div class="restore-hidden-art" aria-hidden="true">
                    <img class="restore-hidden-card restore-hidden-card-main" src="~/Assets/Images/Icons/restore-hidden.svg" alt="">
                    <img class="restore-hidden-card restore-hidden-card-accent" src="~/Assets/Images/Icons/hidden-chat-spark.svg" alt="">
                </div>
                <p class="restore-hidden-copy">Hidden conversations will return to your chat list with their messages unchanged.</p>
                <div class="restore-hidden-actions">
                    <button class="secondary-icon-button" type="button" data-close-modal>
                        <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                        <span>Cancel</span>
                    </button>
                    <button class="primary-icon-button" id="confirmRestoreHiddenButton" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/restore-hidden.svg" alt="">
                        <span>Show</span>
                    </button>
                </div>
            </div>
        </section>
    </div>

    <div class="modal-backdrop restore-hidden-backdrop" id="deleteFriendModal" aria-hidden="true">
        <section class="modal-panel confirm-modal-panel restore-hidden-panel" role="dialog" aria-modal="true" aria-labelledby="deleteFriendTitle">
            <header class="modal-header">
                <h2 id="deleteFriendTitle">Delete friend?</h2>
                <button class="icon-button" type="button" data-close-modal aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="confirm-modal-body">
                <div class="restore-hidden-art" aria-hidden="true">
                    <img class="restore-hidden-card restore-hidden-card-main" src="~/Assets/Images/Icons/remove-friend.svg" alt="">
                    <img class="restore-hidden-card restore-hidden-card-accent" src="~/Assets/Images/Icons/confirm-delete.svg" alt="">
                </div>
                <p class="restore-hidden-copy" id="deleteFriendCopy">This friend and the entire chat history will be permanently deleted.</p>
                <div class="restore-hidden-actions">
                    <button class="secondary-icon-button" type="button" data-close-modal>
                        <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                        <span>Cancel</span>
                    </button>
                    <button class="primary-icon-button danger-icon-button" id="confirmDeleteFriendButton" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/remove-friend.svg" alt="">
                        <span>Delete</span>
                    </button>
                </div>
            </div>
        </section>
    </div>

    <div class="modal-backdrop" id="allFriendsModal" aria-hidden="true">
        <section class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="allFriendsTitle">
            <header class="modal-header">
                <h2 id="allFriendsTitle">All friends</h2>
                <button class="icon-button" type="button" data-close-modal aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="modal-list" id="allFriendsList"></div>
        </section>
    </div>

    <div class="modal-backdrop" id="friendRequestsModal" aria-hidden="true">
        <section class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="friendRequestsTitle">
            <header class="modal-header">
                <h2 id="friendRequestsTitle">Friend requests</h2>
                <button class="icon-button" type="button" data-close-modal aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="modal-list" id="friendRequestsList"></div>
        </section>
    </div>

    <div class="modal-backdrop call-modal-backdrop" id="callModal" aria-hidden="true">
        <section class="modal-panel confirm-modal-panel call-modal-panel" role="dialog" aria-modal="true" aria-labelledby="callUserName">
            <div class="call-modal-body">
                <div class="call-avatar-ring" aria-hidden="true">
                    <span class="avatar call-avatar" id="callAvatar">E</span>
                </div>
                <div class="call-copy">
                    <h2 id="callUserName">Audio call</h2>
                    <strong id="callDuration">00:00</strong>
                </div>
                <div class="call-actions" aria-label="Call controls">
                    <button class="call-control-button" id="collapseCallButton" type="button" aria-label="Close call window" title="Close call window">
                        <img class="button-icon" src="~/Assets/Images/Icons/call-collapse.svg" alt="">
                        <span>Close</span>
                    </button>
                    <button class="call-control-button" id="speakerCallButton" type="button" aria-label="Change speaker" title="Change speaker">
                        <img class="button-icon" src="~/Assets/Images/Icons/speaker.svg" alt="">
                        <span id="callSpeakerLabel">Speaker</span>
                    </button>
                    <button class="call-control-button" id="muteCallButton" type="button" aria-label="Mute microphone" title="Mute microphone" aria-pressed="false">
                        <img class="button-icon" src="~/Assets/Images/Icons/microphone.svg" alt="">
                        <span id="muteCallLabel">Mute</span>
                    </button>
                    <button class="call-control-button call-end-button" id="endCallButton" type="button" aria-label="End call" title="End call">
                        <img class="button-icon" src="~/Assets/Images/Icons/call-end.svg" alt="">
                        <span>End</span>
                    </button>
                </div>
                <div class="call-no-answer-actions" aria-label="No answer actions" hidden>
                    <button class="call-result-button call-exit-button" id="exitNoAnswerButton" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                        <span>Exit</span>
                    </button>
                    <button class="call-result-button call-again-button" id="retryCallButton" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/call-again.svg" alt="">
                        <span>Retry</span>
                    </button>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    window.elovoCurrentUserId = "@ViewBag.CurrentUserId";
    if (window.AndroidBridge) {
        window.AndroidBridge.onUserLoggedIn(window.elovoCurrentUserId);
    }
    window.elovoCurrentUserProfileImageUrl = "@ViewBag.CurrentUserProfileImageUrl";
</script>

@section Scripts {
    <script src="~/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/Assets/Script/chat.js" asp-append-version="true"></script>
}
