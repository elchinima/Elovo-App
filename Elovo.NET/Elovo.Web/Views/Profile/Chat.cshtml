@{
    ViewData["Title"] = "Elovo Chat Settings";
}

<main class="app-shell">
    <section class="profile-view is-active" id="chatSettingsView" aria-label="Chat settings">
        <header class="profile-topbar">
            <a class="icon-button" asp-controller="Chat" asp-action="Index" aria-label="Back to chat" title="Back to chat">
                <img class="button-icon" src="~/Assets/Images/Icons/back.svg" alt="">
            </a>
            <div>
                <p class="eyebrow">Settings</p>
                <h1>Chats</h1>
            </div>
            <nav class="settings-nav" aria-label="Settings navigation">
                <a class="settings-nav-button" asp-controller="Profile" asp-action="Index">
                    <img class="button-icon" src="~/Assets/Images/Icons/user-profile.svg" alt="">
                    <span>User Profile</span>
                </a>
                <a class="settings-nav-button is-active" asp-controller="Profile" asp-action="Chat" aria-current="page">
                    <img class="button-icon" src="~/Assets/Images/Icons/settings-chat.svg" alt="">
                    <span>Chats</span>
                </a>
            </nav>
        </header>

        <div class="profile-grid chat-settings-grid">
            <section class="profile-panel chat-retention-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/chat-retention.svg" alt="">
                    <h2>Automatic message cleanup</h2>
                </div>
                <p class="chat-settings-copy">Delete local chat messages older than the selected period on this browser or mobile app.</p>
                <div class="chat-retention-options" id="chatRetentionOptions" role="radiogroup" aria-label="Auto delete old messages"></div>
                <p class="profile-status" id="chatRetentionStatus"></p>
            </section>
        </div>
    </section>

    <div class="modal-backdrop" id="chatRetentionConfirmModal" aria-hidden="true">
        <section class="modal-panel confirm-modal-panel profile-confirm-panel" role="dialog" aria-modal="true" aria-labelledby="chatRetentionConfirmTitle">
            <header class="modal-header">
                <h2 id="chatRetentionConfirmTitle">Change cleanup period?</h2>
                <button class="icon-button" type="button" id="chatRetentionConfirmClose" aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="confirm-modal-body">
                <div class="profile-confirm-art" aria-hidden="true">
                    <img class="profile-confirm-card profile-confirm-card-main" src="~/Assets/Images/Icons/confirm-chat-retention.svg" alt="">
                    <img class="profile-confirm-card profile-confirm-card-accent" src="~/Assets/Images/Icons/confirm-spark.svg" alt="">
                </div>
                <p class="profile-confirm-copy" id="chatRetentionConfirmMessage">Old local messages will be deleted after the selected period.</p>
                <div class="profile-confirm-actions">
                    <button class="secondary-icon-button" id="chatRetentionConfirmCancel" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                        <span>Cancel</span>
                    </button>
                    <button class="primary-icon-button" id="chatRetentionConfirmAccept" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/chat-retention.svg" alt="">
                        <span>Confirm</span>
                    </button>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    window.elovoCurrentUserId = "@ViewBag.CurrentUserId";
</script>

@section Scripts {
    <script src="~/Assets/Script/chat-settings.js" asp-append-version="true"></script>
}
