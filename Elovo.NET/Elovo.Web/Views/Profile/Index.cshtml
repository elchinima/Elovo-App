@model Elovo.Application.DTOs.ProfileDto
@{
    ViewData["Title"] = "Elovo Profile";
}

<main class="app-shell">
    <section class="profile-view is-active" id="profileView" aria-label="Profile">
        <header class="profile-topbar">
            <div class="settings-title-row">
                <a class="icon-button" asp-controller="Chat" asp-action="Index" aria-label="Back to chat" title="Back to chat">
                    <img class="button-icon" src="~/Assets/Images/Icons/back.svg" alt="">
                </a>
                <div>
                    <p class="eyebrow">Settings</p>
                    <h1>@Model.Username</h1>
                </div>
            </div>
            <nav class="settings-nav" aria-label="Settings navigation">
                <button class="settings-nav-button is-active" type="button" aria-current="page" disabled>
                    <img class="button-icon" src="~/Assets/Images/Icons/user-profile.svg" alt="">
                    <span>User Profile</span>
                </button>
                <a class="settings-nav-button" asp-controller="Profile" asp-action="Chat">
                    <img class="button-icon settings-nav-preferences-icon" src="~/Assets/Images/Icons/preferences.svg" alt="">
                    <span>Preferences</span>
                </a>
                @if (Model.IsPremium)
                {
                    <a class="settings-nav-button" asp-controller="Profile" asp-action="PremiumActions">
                        <img class="button-icon settings-nav-premium-icon" src="~/Assets/Images/Icons/premium-actions.svg" alt="">
                        <span>Premium actions</span>
                    </a>
                }
            </nav>
        </header>

        <div class="profile-grid">
            <section class="profile-panel profile-avatar-panel">
                <div class="profile-avatar" id="profileAvatar">
                    @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                    {
                        <img src="@Model.ProfileImageUrl" alt="">
                    }
                    else
                    {
                        <span>@Model.Initial</span>
                    }
                </div>
                <div class="profile-panel-copy">
                    <h2>Profile image</h2>
                </div>
                <input class="visually-hidden-file" type="file" id="profileImageInput" accept="image/png,image/jpeg,image/jpg">
                @Html.AntiForgeryToken()
                <div class="profile-actions">
                    <button class="primary-icon-button" id="profileImageButton" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/profile-image.svg" alt="">
                        <span>Choose</span>
                    </button>
                    <button class="secondary-icon-button" id="deleteProfileImageButton" type="button" @(string.IsNullOrWhiteSpace(Model.ProfileImageUrl) ? "disabled" : "")>
                        <img class="button-icon" src="~/Assets/Images/Icons/delete-local.svg" alt="">
                        <span>Delete</span>
                    </button>
                </div>
                <p class="profile-status" id="profileImageStatus"></p>
            </section>

            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/email.svg" alt="">
                    <h2>Email</h2>
                </div>
                <form class="profile-form" id="profileEmailForm">
                    <div class="profile-email-row @(Model.IsEmailConfirmed ? "is-email-confirmed" : "")" id="profileEmailRow">
                        <label class="profile-email-field">
                            Email address
                            <span class="profile-email-input-wrap">
                                <input class="@(Model.IsEmailConfirmed ? "is-email-confirmed" : "")" type="email" id="profileEmail" value="@Model.Email" placeholder="name@example.com" required readonly @(Model.IsEmailConfirmed ? "tabindex=\"-1\"" : "")>
                                <span class="profile-email-confirmed-icon" id="profileEmailConfirmedIcon" aria-label="Email verified" title="Email verified" @(Model.IsEmailConfirmed ? "" : "hidden")>
                                    <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path d="m5 12.4 4.2 4.1L19 6.5" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </span>
                            </span>
                        </label>
                        <button class="profile-field-action" id="profileEmailActionButton" type="submit" aria-label="Edit email" title="Edit email" @(Model.IsEmailConfirmed ? "hidden" : "")>
                            <img class="button-icon" id="profileEmailActionIcon" src="~/Assets/Images/Icons/profile-email-edit.svg" alt="">
                        </button>
                    </div>
                    <button class="profile-email-warning" id="profileEmailVerificationWarning" type="button" hidden>Need to verify email</button>
                    <p class="profile-status" id="profileEmailStatus"></p>
                </form>
            </section>

            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/password.svg" alt="">
                    <h2>Password</h2>
                </div>
                <button class="primary-icon-button" id="profilePasswordOpen" type="button">
                    <img class="button-icon" src="~/Assets/Images/Icons/password.svg" alt="">
                    <span>Change password</span>
                </button>
            </section>

            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/two-factor.svg" alt="">
                    <h2>Two-factor authentication</h2>
                </div>
                <div class="profile-toggle-row">
                    <div>
                        <strong>Email code on every sign in</strong>
                        <span>A 7-digit code will be sent to your email each time you sign in.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="twoFactorToggle" @(Model.IsTwoFactorEnabled ? "checked" : "")>
                        <span></span>
                    </label>
                </div>
                <p class="profile-status" id="twoFactorStatus"></p>
            </section>

            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/user-profile.svg" alt="">
                    <h2>Activity visibility</h2>
                </div>
                <button class="activity-visibility-card" id="activityVisibilityOpen" type="button">
                    <span class="activity-visibility-card-icon">
                        <img class="activity-visibility-icon" id="activityVisibilityCurrentIcon" src="~/Assets/Images/Icons/activity-full.svg" alt="">
                    </span>
                    <span class="activity-visibility-card-copy">
                        <strong id="activityVisibilityCurrentLabel">Show online status and last seen</strong>
                        <span>Selected</span>
                    </span>
                    <span class="activity-visibility-card-action">Change</span>
                </button>
                <p class="chat-settings-copy">Note: this applies to both users in the chat.</p>
                <p class="profile-status" id="activityVisibilityStatus"></p>
            </section>

            <section class="profile-panel profile-logout-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/logout.svg" alt="">
                    <h2>Log out</h2>
                </div>
                <p class="chat-settings-copy">End your session on this device.</p>
                <button class="primary-icon-button profile-logout-button" id="profileLogoutButton" type="button">
                    <img class="button-icon" src="~/Assets/Images/Icons/logout.svg" alt="">
                    <span>Log out</span>
                </button>
                <p class="profile-status" id="profileLogoutStatus"></p>
            </section>
        </div>
    </section>

    <div class="modal-backdrop" id="avatarCropModal" aria-hidden="true">
        <section class="modal-panel avatar-crop-panel" role="dialog" aria-modal="true" aria-labelledby="avatarCropTitle">
            <header class="modal-header">
                <h2 id="avatarCropTitle">Crop profile image</h2>
                <button class="icon-button" type="button" id="avatarCropCancel" aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="avatar-crop-body">
                <div class="avatar-crop-stage" id="avatarCropStage">
                    <img id="avatarCropImage" alt="">
                </div>
                <label class="avatar-zoom">
                    Zoom
                    <input type="range" id="avatarZoom" min="1" max="3" step="0.01" value="1">
                </label>
                <button class="primary-icon-button" id="avatarCropSave" type="button">
                    <img class="button-icon" src="~/Assets/Images/Icons/profile-image.svg" alt="">
                    <span>Save</span>
                </button>
            </div>
        </section>
    </div>

    <div class="modal-backdrop" id="profilePasswordModal" aria-hidden="true">
        <section class="modal-panel profile-password-panel" role="dialog" aria-modal="true" aria-labelledby="profilePasswordTitle">
            <header class="modal-header">
                <h2 id="profilePasswordTitle">Change password</h2>
                <button class="icon-button" type="button" id="profilePasswordClose" aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <form class="profile-form profile-password-form" id="profilePasswordForm">
                <label>
                    Current password
                    <input type="password" id="currentPassword" autocomplete="current-password" required>
                </label>
                <label>
                    New password
                    <input type="password" id="newPassword" autocomplete="new-password" minlength="8" maxlength="128" required>
                </label>
                <p class="profile-status" id="profilePasswordStatus"></p>
                <div class="profile-password-actions">
                    <button class="secondary-icon-button" id="profilePasswordCancel" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                        <span>Cancel</span>
                    </button>
                    <button class="primary-icon-button" type="submit">
                        <img class="button-icon" src="~/Assets/Images/Icons/profile-email-save.svg" alt="">
                        <span>Save</span>
                    </button>
                </div>
            </form>
        </section>
    </div>

    <div class="modal-backdrop" id="profileEmailVerifyModal" aria-hidden="true">
        <section class="modal-panel profile-password-panel" role="dialog" aria-modal="true" aria-labelledby="profileEmailVerifyTitle">
            <header class="modal-header">
                <h2 id="profileEmailVerifyTitle">Email verification</h2>
                <button class="icon-button" type="button" id="profileEmailVerifyClose" aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <form class="profile-form profile-password-form" id="profileEmailVerifyForm">
                <p class="chat-settings-copy">Enter the 7 digit code sent to your email.</p>
                <p class="chat-settings-copy">After verification, this email cannot be removed or changed.</p>
                <label>
                    Code
                    <input type="text" id="profileEmailVerifyCode" inputmode="numeric" pattern="[0-9]{7}" maxlength="7" autocomplete="one-time-code" required>
                </label>
                <p class="profile-status" id="profileEmailVerifyStatus"></p>
                <div class="profile-password-actions">
                    <button class="secondary-icon-button" id="profileEmailVerifyResend" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/email.svg" alt="">
                        <span>Send code</span>
                    </button>
                    <button class="primary-icon-button" type="submit">
                        <img class="button-icon" src="~/Assets/Images/Icons/two-factor.svg" alt="">
                        <span>Verify</span>
                    </button>
                </div>
            </form>
        </section>
    </div>

    <div class="modal-backdrop" id="activityVisibilityModal" aria-hidden="true">
        <section class="modal-panel activity-visibility-panel" role="dialog" aria-modal="true" aria-labelledby="activityVisibilityTitle">
            <header class="modal-header">
                <h2 id="activityVisibilityTitle">Activity visibility</h2>
                <button class="icon-button" type="button" id="activityVisibilityClose" aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="activity-visibility-options" id="activityVisibilityOptions">
                <button class="activity-visibility-option" type="button" data-visibility="full">
                    <img class="activity-visibility-icon" src="~/Assets/Images/Icons/activity-full.svg" alt="">
                    <span>
                        <strong>Show online status and last seen</strong>
                    </span>
                </button>
                <button class="activity-visibility-option" type="button" data-visibility="online">
                    <img class="activity-visibility-icon" src="~/Assets/Images/Icons/activity-online.svg" alt="">
                    <span>
                        <strong>Show only when online</strong>
                    </span>
                </button>
                <button class="activity-visibility-option" type="button" data-visibility="hidden">
                    <img class="activity-visibility-icon" src="~/Assets/Images/Icons/activity-hidden.svg" alt="">
                    <span>
                        <strong>Show nothing</strong>
                    </span>
                </button>
            </div>
        </section>
    </div>

    <div class="modal-backdrop" id="profileConfirmModal" aria-hidden="true">
        <section class="modal-panel confirm-modal-panel profile-confirm-panel" role="dialog" aria-modal="true" aria-labelledby="profileConfirmTitle">
            <header class="modal-header">
                <h2 id="profileConfirmTitle">Confirm action</h2>
                <button class="icon-button" type="button" id="profileConfirmClose" aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="confirm-modal-body">
                <div class="profile-confirm-art" aria-hidden="true">
                    <img class="profile-confirm-card profile-confirm-card-main" id="profileConfirmIcon" src="~/Assets/Images/Icons/confirm-profile.svg" alt="">
                    <img class="profile-confirm-card profile-confirm-card-accent" id="profileConfirmAccent" src="~/Assets/Images/Icons/confirm-spark.svg" alt="">
                </div>
                <p class="profile-confirm-copy" id="profileConfirmMessage">Are you sure?</p>
                <div class="profile-confirm-actions">
                    <button class="secondary-icon-button" id="profileConfirmCancel" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                        <span>Cancel</span>
                    </button>
                    <button class="primary-icon-button" id="profileConfirmAccept" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/sent-action.svg" alt="">
                        <span>Confirm</span>
                    </button>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    window.elovoCurrentUserId = "@Model.Id";
    window.elovoProfile = {
        username: "@Model.Username",
        email: @Json.Serialize(Model.Email),
        initial: "@Model.Initial",
        profileImageUrl: "@Model.ProfileImageUrl",
        hasEmail: @Json.Serialize(!string.IsNullOrWhiteSpace(Model.Email)),
        isEmailConfirmed: @Json.Serialize(Model.IsEmailConfirmed),
        emailCooldownEndsAt: @Json.Serialize(Model.EmailCooldownEndsAt),
        isTwoFactorEnabled: @Json.Serialize(Model.IsTwoFactorEnabled),
        activityVisibility: @Json.Serialize(Model.ActivityVisibility)
    };
</script>

@section Scripts {
    <script src="~/Assets/Script/profile.js" asp-append-version="true"></script>
}
