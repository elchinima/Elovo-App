@model Elovo.Application.DTOs.ProfileDto
@{
    ViewData["Title"] = "Elovo Premium Actions";
}

<main class="app-shell">
    <section class="profile-view is-active" id="premiumActionsView" aria-label="Premium actions">
        <header class="profile-topbar">
            <div class="settings-title-row">
                <a class="icon-button" asp-controller="Chat" asp-action="Index" aria-label="Back to chat" title="Back to chat">
                    <img class="button-icon" src="~/Assets/Images/Icons/back.svg" alt="">
                </a>
                <div>
                    <p class="eyebrow">Settings</p>
                    <h1>Premium actions</h1>
                </div>
            </div>
            <nav class="settings-nav" aria-label="Settings navigation">
                <a class="settings-nav-button" asp-controller="Profile" asp-action="Index">
                    <img class="button-icon" src="~/Assets/Images/Icons/user-profile.svg" alt="">
                    <span>User Profile</span>
                </a>
                <a class="settings-nav-button" asp-controller="Profile" asp-action="Chat">
                    <img class="button-icon settings-nav-preferences-icon" src="~/Assets/Images/Icons/preferences.svg" alt="">
                    <span>Preferences</span>
                </a>
                <button class="settings-nav-button is-active" type="button" aria-current="page" disabled>
                    <img class="button-icon settings-nav-premium-icon" src="~/Assets/Images/Icons/premium-actions.svg" alt="">
                    <span>Premium actions</span>
                </button>
            </nav>
        </header>

        <div class="profile-grid chat-settings-grid">
            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/premium-actions.svg" alt="">
                    <h2>Premium actions</h2>
                </div>
                <p class="chat-settings-copy">Premium management options will appear here.</p>
                <div class="profile-toggle-row">
                    <div>
                        <strong>Premium status</strong>
                        <span>@(Model.IsPremium ? "Active" : "Not active")</span>
                    </div>
                </div>
            </section>
        </div>
    </section>
</main>
