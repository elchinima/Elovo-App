@model Elovo.Application.DTOs.ProfileDto
@{
    ViewData["Title"] = "Elovo Premium Actions";
}

<main class="app-shell">
    @Html.AntiForgeryToken()
    <section class="profile-view premium-actions-view is-active" id="premiumActionsView" aria-label="Premium actions">
        <header class="profile-topbar">
            <div class="settings-title-row">
                <a class="icon-button" asp-controller="Chat" asp-action="Index" aria-label="Back to chat" title="Back to chat">
                    <img class="button-icon" src="~/Assets/Images/Icons/back.svg" alt="">
                </a>
                <div>
                    <p class="eyebrow">Settings</p>
                    <h1>Premium actions</h1>
                </div>
            </div>
            <nav class="settings-nav" aria-label="Settings navigation">
                <a class="settings-nav-button" asp-controller="Profile" asp-action="Index">
                    <img class="button-icon" src="~/Assets/Images/Icons/user-profile.svg" alt="">
                    <span>User Profile</span>
                </a>
                <a class="settings-nav-button" asp-controller="Profile" asp-action="Chat">
                    <img class="button-icon settings-nav-preferences-icon" src="~/Assets/Images/Icons/preferences.svg" alt="">
                    <span>Preferences</span>
                </a>
                <button class="settings-nav-button is-active" type="button" aria-current="page" disabled>
                    <img class="button-icon settings-nav-premium-icon" src="~/Assets/Images/Icons/premium-actions.svg" alt="">
                    <span>Premium actions</span>
                </button>
            </nav>
        </header>

        <div class="profile-grid chat-settings-grid">
            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/premium.svg" alt="">
                    <h2>Premium status</h2>
                </div>
                <p class="chat-settings-copy">Your current Premium access state.</p>
                <div class="profile-toggle-row">
                    <div>
                        <strong>Premium status</strong>
                        <span>@(Model.IsPremium ? "Active" : "Not active")</span>
                    </div>
                </div>
            </section>

            <section class="profile-panel profile-avatar-panel">
                <div class="profile-avatar" id="premiumProfileAvatar">
                    @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                    {
                        <img src="@Model.ProfileImageUrl" alt="">
                    }
                    else
                    {
                        <span>@Model.Initial</span>
                    }
                </div>
                <div class="profile-panel-copy">
                    <h2>Premium profile image</h2>
                    <span>Upload a high-quality 512x512 profile image while Premium is active.</span>
                </div>
                <input class="visually-hidden-file" type="file" id="premiumProfileImageInput" accept="image/png,image/jpeg,image/jpg">
                <div class="profile-actions">
                    <button class="primary-icon-button" id="premiumProfileImageButton" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/profile-image.svg" alt="">
                        <span>Choose</span>
                    </button>
                    <button class="secondary-icon-button" id="deletePremiumProfileImageButton" type="button" @(string.IsNullOrWhiteSpace(Model.ProfileImageUrl) ? "disabled" : "")>
                        <img class="button-icon" src="~/Assets/Images/Icons/delete-local.svg" alt="">
                        <span>Delete</span>
                    </button>
                </div>
                <p class="profile-status" id="premiumProfileImageStatus"></p>
            </section>

            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/premium-voice.svg" alt="">
                    <h2>Voice messages</h2>
                </div>
                <p class="chat-settings-copy">Control the Premium voice message duration limit.</p>
                <div class="profile-toggle-row">
                    <div>
                        <strong>3-minute voice messages</strong>
                        <span>Allow voice messages up to 3 minutes while Premium is active.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="extendedVoiceMessagesToggle" @(Model.IsExtendedVoiceMessagesEnabled ? "checked" : "")>
                        <span></span>
                    </label>
                </div>
                <p class="profile-status" id="extendedVoiceMessagesStatus"></p>
            </section>

            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/premium-badge.svg" alt="">
                    <h2>Premium badge</h2>
                </div>
                <p class="chat-settings-copy">Choose whether other users can see your Premium badge.</p>
                <div class="profile-toggle-row">
                    <div>
                        <strong>Premium badge near username</strong>
                        <span>Show your Premium badge next to your name for other users.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="premiumBadgeToggle" @(Model.IsPremiumBadgeVisible ? "checked" : "")>
                        <span></span>
                    </label>
                </div>
                <p class="profile-status" id="premiumBadgeStatus"></p>
            </section>

            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/premium-photo-quality.svg" alt="">
                    <h2>Image quality</h2>
                </div>
                <p class="chat-settings-copy">Control whether sent images keep their original quality.</p>
                <div class="profile-toggle-row">
                    <div>
                        <strong>Quality image without compression</strong>
                        <span>Send image messages in Raw format while Premium is active.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="rawImageUploadsToggle" @(Model.IsRawImageUploadsEnabled ? "checked" : "")>
                        <span></span>
                    </label>
                </div>
                <p class="profile-status" id="rawImageUploadsStatus"></p>
            </section>
            <section class="profile-panel">
                <div class="profile-panel-heading">
                    <img src="~/Assets/Images/Icons/premium-video-quality.svg" alt="" onerror="this.src='/Assets/Images/Icons/premium-photo-quality.svg'">
                    <h2>Video uploads</h2>
                </div>
                <p class="chat-settings-copy">Control whether you can send video messages.</p>
                <div class="profile-toggle-row">
                    <div>
                        <strong>Video file sending</strong>
                        <span>Send video files up to 50MB while Premium is active.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="videoUploadsToggle" @(Model.IsVideoUploadsEnabled ? "checked" : "")>
                        <span></span>
                    </label>
                </div>
                <p class="profile-status" id="videoUploadsStatus"></p>
            </section>
        </div>
    </section>

    <div class="modal-backdrop" id="avatarCropModal" aria-hidden="true">
        <section class="modal-panel avatar-crop-panel" role="dialog" aria-modal="true" aria-labelledby="avatarCropTitle">
            <header class="modal-header">
                <h2 id="avatarCropTitle">Crop profile image</h2>
                <button class="icon-button" type="button" id="avatarCropCancel" aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="avatar-crop-body">
                <div class="avatar-crop-stage" id="avatarCropStage">
                    <img id="avatarCropImage" alt="">
                </div>
                <label class="avatar-zoom">
                    Zoom
                    <input type="range" id="avatarZoom" min="1" max="3" step="0.01" value="1">
                </label>
                <button class="primary-icon-button" id="avatarCropSave" type="button">
                    <img class="button-icon" src="~/Assets/Images/Icons/profile-image.svg" alt="">
                    <span>Save</span>
                </button>
            </div>
        </section>
    </div>

    <div class="modal-backdrop" id="fileLimitModal" aria-hidden="true">
        <section class="modal-panel confirm-modal-panel" role="dialog" aria-modal="true" aria-labelledby="fileLimitTitle">
            <header class="modal-header">
                <h2 id="fileLimitTitle">File too large</h2>
                <button class="icon-button" type="button" data-close-modal aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="confirm-modal-body">
                <p class="restore-hidden-copy" id="fileLimitCopy" style="text-align: center; font-size: 1.1rem;"></p>
                <div class="restore-hidden-actions">
                    <button class="primary-icon-button" type="button" data-close-modal>
                        <span>OK</span>
                    </button>
                </div>
            </div>
        </section>
    </div>

    <div class="modal-backdrop" id="profileConfirmModal" aria-hidden="true">
        <section class="modal-panel confirm-modal-panel profile-confirm-panel" role="dialog" aria-modal="true" aria-labelledby="profileConfirmTitle">
            <header class="modal-header">
                <h2 id="profileConfirmTitle">Confirm action</h2>
                <button class="icon-button" type="button" id="profileConfirmClose" aria-label="Close" title="Close">
                    <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                </button>
            </header>
            <div class="confirm-modal-body">
                <div class="profile-confirm-art" aria-hidden="true">
                    <img class="profile-confirm-card profile-confirm-card-main" id="profileConfirmIcon" src="~/Assets/Images/Icons/confirm-profile.svg" alt="">
                    <img class="profile-confirm-card profile-confirm-card-accent" id="profileConfirmAccent" src="~/Assets/Images/Icons/confirm-spark.svg" alt="">
                </div>
                <p class="profile-confirm-copy" id="profileConfirmMessage">Are you sure?</p>
                <div class="profile-confirm-actions">
                    <button class="secondary-icon-button" id="profileConfirmCancel" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/close.svg" alt="">
                        <span>Cancel</span>
                    </button>
                    <button class="primary-icon-button" id="profileConfirmAccept" type="button">
                        <img class="button-icon" src="~/Assets/Images/Icons/sent-action.svg" alt="">
                        <span>Confirm</span>
                    </button>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    window.elovoPremiumActions = {
        isExtendedVoiceMessagesEnabled: @Json.Serialize(Model.IsExtendedVoiceMessagesEnabled),
        isRawImageUploadsEnabled: @Json.Serialize(Model.IsRawImageUploadsEnabled),
        isVideoUploadsEnabled: @Json.Serialize(Model.IsVideoUploadsEnabled),
        isPremiumBadgeVisible: @Json.Serialize(Model.IsPremiumBadgeVisible)
    };
    window.elovoProfile = {
        username: "@Model.Username",
        initial: "@Model.Initial",
        profileImageUrl: "@Model.ProfileImageUrl"
    };
</script>

@section Scripts {
    <script src="~/Assets/Script/premium-actions.js" asp-append-version="true"></script>
}
