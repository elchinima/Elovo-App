@model ErrorViewModel
@{
    ViewData["Title"] = $"{Model.StatusCode} - {Model.Title}";
}

<main class="app-shell error-shell">
    <section class="error-card" aria-label="Error page">
        <div class="error-code">@Model.StatusCode</div>
        <div class="error-content">
            <p class="eyebrow">Elovo Error</p>
            <h1>@Model.Title</h1>
            <p class="support-copy">@Model.Message</p>
            <div class="error-actions">
                <a asp-controller="Chat" asp-action="Index" class="primary-link-button">Back to chat</a>
                <a asp-controller="Auth" asp-action="Login" class="secondary-button">Login page</a>
            </div>
            @if (Model.ShowRequestId)
            {
                <p class="fine-print">Request ID: <code>@Model.RequestId</code></p>
            }
        </div>
    </section>
</main>
