{
  "ConnectionStrings": {
    "Default": "Set via ConnectionStrings__Default environment variable"
  },
  "Jwt": {
    "Secret": "Set via Jwt__Secret environment variable",
    "Issuer": "Elovo",
    "Audience": "ElovoUsers",
    "ExpiryDays": 7
  },
  "Supabase": {
    "Url": "Set via Supabase__Url environment variable",
    "StorageBucket": "chat-images",
    "ProfileImagesBucket": "profile-images",
    "ServiceRoleKey": "Set via Supabase__ServiceRoleKey environment variable"
  },
  "Email": {
    "SmtpHost": "Set via Email__SmtpHost environment variable",
    "SmtpPort": "587",
    "SmtpUsername": "Set via Email__SmtpUsername environment variable",
    "SmtpPassword": "Set via Email__SmtpPassword environment variable",
    "EnableSsl": "true",
    "From": "Set via Email__From environment variable",
    "FromName": "Elovo Messages"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
